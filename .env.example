OPENJOURNEY_DEV_API_KEY=replace-for-local-development
OPENJOURNEY_ADMIN_EMAIL=admin@example.test
OPENJOURNEY_ADMIN_PASSWORD=replace-with-at-least-12-characters
OPENJOURNEY_SESSION_TTL=12h
OPENJOURNEY_DATABASE_URL=postgres://openjourney:openjourney@localhost:5432/openjourney?sslmode=disable
OPENJOURNEY_HTTP_ADDRESS=:8080
OPENJOURNEY_MAX_BATCH_SIZE=75
OPENJOURNEY_AUTO_MIGRATE=true
OPENJOURNEY_CORS_ALLOWED_ORIGIN=http://localhost:3000
# Optional external SSO. Leave empty for the built-in self-hosted login.
OPENJOURNEY_OIDC_ISSUER=
OPENJOURNEY_OIDC_CLIENT_ID=
OPENJOURNEY_KAFKA_BROKERS=
OPENJOURNEY_S3_ENDPOINT=localhost:9000
OPENJOURNEY_S3_ACCESS_KEY=openjourney
OPENJOURNEY_S3_SECRET_KEY=replace-me
OPENJOURNEY_S3_BUCKET=openjourney
OPENJOURNEY_S3_USE_TLS=false
OPENJOURNEY_CLICKHOUSE_ADDRESS=localhost:9009
OPENJOURNEY_CLICKHOUSE_DATABASE=openjourney
OPENJOURNEY_CLICKHOUSE_USERNAME=openjourney
OPENJOURNEY_CLICKHOUSE_PASSWORD=replace-me
OPENJOURNEY_OTLP_ENDPOINT=
OPENJOURNEY_SERVICE_VERSION=dev
